{
    "manifest_version": 3,
    "name": "EmpowerNet Safety Panel",
    "version": "1.0.0",
    "description": "AI-powered scam & deepfake detection for your browser.",
    "permissions": [
        "activeTab",
        "scripting",
        "contextMenus",
        "storage",
        "webNavigation",
        "audio",
        "tabs",
        "tabCapture",
        "offscreen"
    ],
    "host_permissions": [
        "http://localhost:8001/*",
        "https://meet.google.com/*",
        "https://*.zoom.us/*",
        "https://web.whatsapp.com/*",
        "https://*.instagram.com/*",
        "https://*.youtube.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js",
                "child_safety.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://meet.google.com/*",
                "https://*.zoom.us/*",
                "https://web.whatsapp.com/*"
            ],
            "js": [
                "meeting_content.js"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://*.instagram.com/*",
                "https://instagram.com/*",
                "https://*.youtube.com/*",
                "https://youtube.com/*"
            ],
            "js": [
                "media_scanner.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}